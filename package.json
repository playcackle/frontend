{
  "name": "cackle",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "analyze": "ANALYZE=true next build --webpack",
    "dev": "next dev",
    "lint": "echo 'ESLint not yet configured — skipping'",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "check:sourcemaps": "find .next -name '*.map' | wc -l",
    "build:check": "next build && npm run check:sourcemaps",
    "validate": "npm run typecheck && npm run test"
  },
