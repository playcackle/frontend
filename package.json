    "@sentry/nextjs": "^10.53.1",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.106.0",
    "autoprefixer": "^10.5.0",
    "canvas-confetti": "^1.9.4",
    "cmdk": "1.1.1",
    "date-fns": "^4.2.1",
    "gsap": "^3.15.0",
    "input-otp": "1.4.2",
    "jotai": "^2.20.0",
    "jotai-devtools": "^0.14.0",
    "lucide-react": "^1.16.0",
    "next": "^16.0.10",
