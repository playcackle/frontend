    "@types/react": "19.2.15",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^28.1.0",
    "postcss": "^8.5.15",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
